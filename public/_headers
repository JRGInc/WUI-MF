# Keep the service worker and app shell from being edge/browser cached,
# so autoUpdate PWA clients pick up new builds instead of sticking on a
# stale bundle. Hashed assets under /assets/* are immutable and cached hard.
/sw.js
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
/assets/*
  Cache-Control: public, max-age=31536000, immutable
